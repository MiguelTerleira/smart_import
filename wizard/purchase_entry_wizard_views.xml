<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_entry_wizard_form" model="ir.ui.view">
        <field name="name">purchase.entry.wizard.form</field>
        <field name="model">smart.import.purchase.entry.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar entrada SmartImport">
                <group>
                    <field name="purchase_id" readonly="1"/>
                    <field name="purchase_line_id"/>
                    <field name="product_id" readonly="1"/>
                    <field name="quantity"/>
                    <field name="location_destination_id"/>
                    <field name="notes"/>
                </group>

                <footer>
                    <button name="action_register_entry"
                            type="object"
                            string="Registrar entrada"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>