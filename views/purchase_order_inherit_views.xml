<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_order_inherit_form_smart_import" model="ir.ui.view">
        <field name="name">purchase.order.inherit.form.smart.import</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_smart_import_entry_wizard"
                        type="object"
                        string="Registrar entrada SmartImport"
                        class="btn-primary"/>
            </xpath>
        </field>
    </record>

</odoo>