<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción -->
    <record id="action_transfer_request" model="ir.actions.act_window">
        <field name="name">Solicitudes de transferencia</field>
        <field name="res_model">smart.import.transfer.request</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Vista lista -->
    <record id="view_transfer_request_tree" model="ir.ui.view">
        <field name="name">transfer.request.tree</field>
        <field name="model">smart.import.transfer.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="location_origin_id"/>
                <field name="location_destination_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_transfer_request_form" model="ir.ui.view">
        <field name="name">transfer.request.form</field>
        <field name="model">smart.import.transfer.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_execute_transfer"
                            type="object"
                            string="Ejecutar transferencia"
                            invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="quantity"/>
                    </group>

                    <group>
                        <field name="location_origin_id"/>
                        <field name="location_destination_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>