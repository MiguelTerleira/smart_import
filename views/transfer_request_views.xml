<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción -->
    <record id="action_transfer_request" model="ir.actions.act_window">
        <field name="name">Solicitudes de transferencia</field>
        <field name="res_model">smart.import.transfer.request</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <!-- Vista kanban -->
    <record id="view_transfer_request_kanban" model="ir.ui.view">
        <field name="name">transfer.request.kanban</field>
        <field name="model">smart.import.transfer.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_mobile">
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="location_origin_id"/>
                <field name="location_destination_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_head">
                                <strong class="o_kanban_record_title">
                                    <field name="product_id"/>
                                </strong>
                            </div>

                            <div class="mt8">
                                <div><strong>Cantidad:</strong> <field name="quantity"/></div>
                                    <div><strong>Ubicación solicitante:</strong> <field name="location_destination_id"/></div>
                                    <div><strong>Ubicación de suministro:</strong> <field name="location_origin_id"/></div>
                                <div class="mt8">
                                    <strong>Estado:</strong>
                                    <t t-if="record.state.raw_value == 'pending'">
                                        <span class="badge rounded-pill text-bg-warning">Pendiente</span>
                                    </t>
                                    <t t-if="record.state.raw_value == 'done'">
                                        <span class="badge rounded-pill text-bg-success">Completado</span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista lista -->
    <record id="view_transfer_request_tree" model="ir.ui.view">
        <field name="name">transfer.request.tree</field>
        <field name="model">smart.import.transfer.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="location_destination_id" string="Ubicación solicitante"/>
                <field name="location_origin_id" string="Ubicación de suministro"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_transfer_request_form" model="ir.ui.view">
        <field name="name">transfer.request.form</field>
        <field name="model">smart.import.transfer.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_execute_transfer"
                            type="object"
                            string="Ejecutar transferencia"
                            invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="quantity"/>
                    </group>

                    <group>
                        <field name="location_origin_id" string="Ubicación de suministro"/>
                        <field name="sale_order_id" invisible="1"/>
                        <field name="location_destination_id" string="Ubicación solicitante"  readonly="sale_order_id"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

</odoo>