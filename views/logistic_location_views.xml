<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_smart_import_logistic_location" model="ir.actions.act_window">
        <field name="name">Ubicaciones logísticas</field>
        <field name="res_model">smart.import.logistic.location</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <!-- Vista lista -->
    <record id="view_smart_import_logistic_location_tree" model="ir.ui.view">
        <field name="name">smart.import.logistic.location.tree</field>
        <field name="model">smart.import.logistic.location</field>
        <field name="arch" type="xml">
            <tree string="Ubicaciones logísticas">
                <field name="name"/>
                <field name="code"/>
                <field name="location_type"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <!-- Vista formulario -->
    <record id="view_smart_import_logistic_location_form" model="ir.ui.view">
        <field name="name">smart.import.logistic.location.form</field>
        <field name="model">smart.import.logistic.location</field>
        <field name="arch" type="xml">
            <form string="Ubicación logística">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="location_type"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="street"/>
                            <field name="city"/>
                            <field name="zip"/>
                            <field name="state_id"/>
                            <field name="country_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Descripción">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista búsqueda -->
    <record id="view_smart_import_logistic_location_search" model="ir.ui.view">
        <field name="name">smart.import.logistic.location.search</field>
        <field name="model">smart.import.logistic.location</field>
        <field name="arch" type="xml">
            <search string="Buscar ubicaciones logísticas">
                <field name="name"/>
                <field name="code"/>
                <field name="location_type"/>
                <field name="city"/>

                <separator/>

                <!--<filter name="filter_all" string="Todas" domain="[]"/>(pte revisar, no funciona)-->
                <filter name="filter_active" string="Activas" domain="[('active','=',True)]"/>
                <filter name="filter_inactive" string="Inactivas" domain="[('active','=',False)]"/>

                <group expand="1" string="Agrupar por">
                    <filter name="group_type" string="Tipo" context="{'group_by':'location_type'}"/>
                    <filter name="group_city" string="Ciudad" context="{'group_by':'city'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
