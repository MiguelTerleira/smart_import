<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_smart_import_logistic_location" model="ir.actions.act_window">
        <field name="name">Ubicaciones logísticas</field>
        <field name="res_model">smart.import.logistic.location</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <!-- Vista kanban -->
    <record id="view_smart_import_logistic_location_kanban" model="ir.ui.view">
        <field name="name">smart.import.logistic.location.kanban</field>
        <field name="model">smart.import.logistic.location</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="code"/>
                <field name="location_type"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="p-3">
                                <div class="mb-2">
                                    <strong class="fs-5">
                                        <field name="name"/>
                                    </strong>
                                </div>

                                <div class="mb-2">
                                    <t t-if="record.location_type.raw_value == 'port'">
                                        <span class="badge rounded-pill text-bg-info">Puerto</span>
                                    </t>
                                    <t t-if="record.location_type.raw_value == 'warehouse'">
                                        <span class="badge rounded-pill text-bg-primary">Almacén</span>
                                    </t>
                                    <t t-if="record.location_type.raw_value == 'store'">
                                        <span class="badge rounded-pill text-bg-warning">Punto de venta</span>
                                    </t>
                                </div>

                                <div><strong>Código:</strong> <field name="code"/></div>
                                <div><strong>Ciudad:</strong> <field name="city"/></div>
                                <div><strong>País:</strong> <field name="country_id"/></div>

                                <div class="mt-2">
                                    <strong>Estado:</strong>
                                    <t t-if="record.active.raw_value">
                                        <span class="badge rounded-pill text-bg-success">Activa</span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge rounded-pill text-bg-secondary">Inactiva</span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- Vista formulario -->
    <record id="view_smart_import_logistic_location_form" model="ir.ui.view">
        <field name="name">smart.import.logistic.location.form</field>
        <field name="model">smart.import.logistic.location</field>
        <field name="arch" type="xml">
            <form string="Ubicación logística">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="location_type"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="street"/>
                            <field name="city"/>
                            <field name="zip"/>
                            <field name="state_id"/>
                            <field name="country_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Stock">
                            <field name="stock_ids" readonly="1">
                                <tree>
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Descripción">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista búsqueda -->
    <record id="view_smart_import_logistic_location_search" model="ir.ui.view">
        <field name="name">smart.import.logistic.location.search</field>
        <field name="model">smart.import.logistic.location</field>
        <field name="arch" type="xml">
            <search string="Buscar ubicaciones logísticas">
                <field name="name"/>
                <field name="code"/>
                <field name="location_type"/>
                <field name="city"/>

                <separator/>

                <!--<filter name="filter_all" string="Todas" domain="[]"/>(pte revisar, no funciona)-->
                <filter name="filter_active" string="Activas" domain="[('active','=',True)]"/>
                <filter name="filter_inactive" string="Inactivas" domain="[('active','=',False)]"/>

                <group expand="1" string="Agrupar por">
                    <filter name="group_type" string="Tipo" context="{'group_by':'location_type'}"/>
                    <filter name="group_city" string="Ciudad" context="{'group_by':'city'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
