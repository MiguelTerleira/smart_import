<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- acciones -->
    <record id="action_smart_import_entries" model="ir.actions.act_window">
        <field name="name">Entradas de mercancía</field>
        <field name="res_model">smart.import.movement</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('movement_type', '=', 'in')]</field>
        <field name="context">{'default_movement_type': 'in'}</field>
    </record>

    <record id="action_smart_import_transfers" model="ir.actions.act_window">
        <field name="name">Transferencias internas</field>
        <field name="res_model">smart.import.movement</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('movement_type', '=', 'transfer')]</field>
        <field name="context">{'default_movement_type': 'transfer'}</field>
    </record>

    <record id="action_smart_import_outputs" model="ir.actions.act_window">
        <field name="name">Salidas de mercancía</field>
        <field name="res_model">smart.import.movement</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('movement_type', '=', 'out')]</field>
        <field name="context">{'default_movement_type': 'out'}</field>
    </record>

    <record id="action_smart_import_movement_history" model="ir.actions.act_window">
        <field name="name">Histórico de movimientos</field>
        <field name="res_model">smart.import.movement</field>
        <field name="view_mode">graph,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay movimientos registrados.
            </p>
            <p>
                Cuando se registren entradas, transferencias o salidas de mercancía, aparecerán en este historial.
            </p>
        </field>
    </record>

    <!-- vista lista entradas -->
    <record id="view_smart_import_movement_entry_tree" model="ir.ui.view">
        <field name="name">smart.import.movement.entry.tree</field>
        <field name="model">smart.import.movement</field>
        <field name="arch" type="xml">
            <tree string="Entradas de mercancía">
                <field name="name"/>
                <field name="date"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="location_destination_id"/>
                <field name="purchase_id"/>
                <field name="user_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- vista lista transferencias -->
    <record id="view_smart_import_movement_transfer_tree" model="ir.ui.view">
        <field name="name">smart.import.movement.transfer.tree</field>
        <field name="model">smart.import.movement</field>
        <field name="arch" type="xml">
            <tree string="Transferencias internas">
                <field name="name"/>
                <field name="date"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="location_origin_id" />
                <field name="location_destination_id"/>
                <field name="user_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- vista lista salidas -->
    <record id="view_smart_import_movement_output_tree" model="ir.ui.view">
        <field name="name">smart.import.movement.output.tree</field>
        <field name="model">smart.import.movement</field>
        <field name="arch" type="xml">
            <tree string="Salidas de mercancía">
                <field name="name"/>
                <field name="date"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="location_origin_id" string="Ubicación de venta"/>
                <field name="sale_id"/>
                <field name="user_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- vista lista histórico -->
    <record id="view_smart_import_movement_history_tree" model="ir.ui.view">
        <field name="name">smart.import.movement.history.tree</field>
        <field name="model">smart.import.movement</field>
        <field name="arch" type="xml">
            <tree string="Histórico de movimientos">
                <field name="name"/>
                <field name="date"/>
                <field name="movement_type"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="location_origin_id"/>
                <field name="location_destination_id"/>
                <field name="purchase_id"/>
                <field name="sale_id"/>
                <field name="user_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Vista gráfica: histórico-->
    <record id="view_smart_import_movement_graph" model="ir.ui.view">
        <field name="name">smart.import.movement.graph</field>
        <field name="model">smart.import.movement</field>
        <field name="arch" type="xml">
            <graph string="Histórico de movimientos" type="bar">
                <field name="date" interval="month"/>
                <field name="quantity" type="measure"/>
                <field name="movement_type"/>
            </graph>
        </field>
    </record>

    <!-- vista formulario -->
    <record id="view_smart_import_movement_form" model="ir.ui.view">
        <field name="name">smart.import.movement.form</field>
        <field name="model">smart.import.movement</field>
        <field name="arch" type="xml">
            <form string="Movimiento de mercancía">
                <header>
                    <button name="action_confirm"
                            type="object"
                            string="Confirmar"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="movement_type"/>
                            <field name="date"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="product_id"/>
                            <field name="quantity"/>
                        </group>
                    </group>

                    <group>
                        <group>
                            <field name="location_origin_id"
                                   invisible="movement_type == 'in'"
                                   required="movement_type in ['out', 'transfer']"/>
                        </group>
                        <group>
                            <field name="location_destination_id"
                                   invisible="movement_type == 'out'"
                                   required="movement_type in ['in', 'transfer']"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Relaciones">
                            <group>
                                <field name="purchase_id"/>
                                <field name="sale_id"/>
                            </group>
                        </page>
                        <page string="Observaciones">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- vista búsqueda -->
    <record id="view_smart_import_movement_search" model="ir.ui.view">
        <field name="name">smart.import.movement.search</field>
        <field name="model">smart.import.movement</field>
        <field name="arch" type="xml">
            <search string="Buscar movimientos">
                <field name="name"/>
                <field name="product_id"/>
                <field name="movement_type"/>
                <field name="date"/>
                <field name="location_origin_id"/>
                <field name="location_destination_id"/>
                <field name="user_id"/>

                <separator/>

                <filter name="filter_in" string="Entradas" domain="[('movement_type','=','in')]"/>
                <filter name="filter_transfer" string="Transferencias" domain="[('movement_type','=','transfer')]"/>
                <filter name="filter_out" string="Salidas" domain="[('movement_type','=','out')]"/>

                <group expand="1" string="Agrupar por">
                    <filter name="group_product" string="Producto" context="{'group_by':'product_id'}"/>
                    <filter name="group_type" string="Tipo" context="{'group_by':'movement_type'}"/>
                    <filter name="group_date" string="Fecha" context="{'group_by':'date'}"/>
                    <filter name="group_user" string="Usuario" context="{'group_by':'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- enlaces a acción de vistas tree -->
    <!-- entradas -->
    <record id="action_smart_import_entries_tree_link" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_smart_import_movement_entry_tree"/>
        <field name="act_window_id" ref="action_smart_import_entries"/>
    </record>

    <!-- transferencias -->
    <record id="action_smart_import_transfers_tree_link" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_smart_import_movement_transfer_tree"/>
        <field name="act_window_id" ref="action_smart_import_transfers"/>
    </record>

    <!-- salidas -->
    <record id="action_smart_import_outputs_tree_link" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_smart_import_movement_output_tree"/>
        <field name="act_window_id" ref="action_smart_import_outputs"/>
    </record>

    <!-- historicco graph -->
    <record id="action_smart_import_history_graph_link" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_smart_import_movement_graph"/>
        <field name="act_window_id" ref="action_smart_import_movement_history"/>
    </record>

    <!-- histórico tree-->
    <record id="action_smart_import_history_tree_link" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_smart_import_movement_history_tree"/>
        <field name="act_window_id" ref="action_smart_import_movement_history"/>
    </record>

</odoo>